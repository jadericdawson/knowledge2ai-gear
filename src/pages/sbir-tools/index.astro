---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'SBIR Tools', href: '/sbir-tools/' }];

const sbirProducts = [
  {
    title: 'Lenovo ThinkPad X1 Carbon Gen 12',
    asin: 'B0D1D5J1J1',
    price: '~$1,299',
    rating: '4.6/5',
    description: 'The SBIR proposal laptop. Business-class reliability, 3-year warranty, MIL-SPEC tested. What proposal writers and technical directors actually use for long-haul writing sessions.',
    badge: 'Top Pick',
  },
  {
    title: 'Canon imageFORMULA DR-C230 Document Scanner',
    asin: 'B07CP2C3H5',
    price: '~$229',
    rating: '4.5/5',
    description: '30ppm duplex scanner. Federal proposals require scanned signatures, forms, and supporting documents. Fastest sub-$300 scanner for proposal work.',
    badge: 'We Use This',
  },
  {
    title: 'APC BX1500M 1500VA UPS Battery Backup',
    asin: 'B06VY6FXMM',
    price: '~$229',
    rating: '4.7/5',
    description: 'Battery backup for workstation. SBIR proposals are due at a specific time — a power blip at 4:57pm on submission day is catastrophic. This prevents that.',
    badge: 'Risk Mitigation',
  },
  {
    title: 'Seagate IronWolf Pro 4TB NAS Drive',
    asin: 'B07SY4T6F5',
    price: '~$89',
    rating: '4.5/5',
    description: 'NAS storage for proposal archives. CUI requirements mean you should not store proposal data in consumer cloud. Local NAS + encryption is the compliant path.',
    badge: null,
  },
  {
    title: 'YubiKey 5 NFC Security Key',
    asin: 'B07HBD71HL',
    price: '~$50',
    rating: '4.7/5',
    description: 'Hardware MFA for SAM.gov, grants.gov, and DoD portals. Required for CMMC compliance track. Tap-to-auth with NFC on phone and USB-A on desktop.',
    badge: 'Compliance',
  },
  {
    title: 'Logitech MX Master 3S Mouse',
    asin: 'B0BS9VVQPD',
    price: '~$99',
    rating: '4.8/5',
    description: 'Precision mouse for long document editing sessions. Quiet clicks for late-night proposal sessions, 8K DPI sensor, multi-device Bluetooth.',
    badge: null,
  },
  {
    title: 'Samsung 970 EVO Plus 1TB NVMe SSD',
    asin: 'B07MFZY2F2',
    price: '~$79',
    rating: '4.8/5',
    description: 'Fast NVMe storage for workstation or laptop secondary drive. Keep proposal archives, reference documents, and project data on fast local storage.',
    badge: null,
  },
  {
    title: 'Jabra Evolve2 55 Wireless Headset UC',
    asin: 'B0BS77T2R1',
    price: '~$279',
    rating: '4.6/5',
    description: 'Enterprise headset for SBIR technical meetings and proposal calls. Noise-canceling mic, UC-certified, 50hr battery. Keeps you sounding professional on agency calls.',
    badge: null,
  },
];

const laptopComparison = [
  { title: 'ThinkPad X1 Carbon Gen 12', asin: 'B0D1D5J1J1', price: '~$1,299', highlight: '3yr warranty, MIL-SPEC', badge: 'Top Pick' },
  { title: 'Canon DR-C230 Scanner', asin: 'B07CP2C3H5', price: '~$229', highlight: '30ppm duplex, USB', badge: null },
  { title: 'APC BX1500M UPS', asin: 'B06VY6FXMM', price: '~$229', highlight: '1500VA, 10 outlets', badge: null },
  { title: 'YubiKey 5 NFC', asin: 'B07HBD71HL', price: '~$50', highlight: 'Hardware MFA, USB+NFC', badge: 'Compliance' },
];
---
<ArticleLayout
  title="SBIR Contractor Home Office Setup"
  description="Home office hardware for federal contractors and SBIR/STTR proposal writers. Laptops, scanners, UPS systems, and security keys for compliant remote work."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-6 text-slate-300">
    <h2 class="text-2xl font-bold text-white">SBIR Home Office Gear</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {sbirProducts.map(p => (
        <AffiliateCard {...p} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">Essential Contractor Gear at a Glance</h2>
    <ProductTable caption="SBIR Contractor Setup — Core Items" products={laptopComparison} />

    <h2 class="text-2xl font-bold text-white pt-4">Compliance Notes</h2>
    <ul class="list-disc list-inside space-y-2 text-sm">
      <li><strong class="text-white">CUI storage:</strong> Use encrypted local NAS (IronWolf + QNAP/Synology + BitLocker/VeraCrypt), not iCloud or Google Drive, for proposal-related documents.</li>
      <li><strong class="text-white">MFA:</strong> YubiKey hardware token for SAM.gov, grants.gov, and any DoD portal. Authenticator apps are acceptable for SBIR portals; hard tokens are better practice.</li>
      <li><strong class="text-white">Software:</strong> Microsoft 365 Government plans required for CUI handling in CMMC Level 2 environments.</li>
    </ul>

    <div class="mt-6 p-4 bg-slate-800 rounded-xl text-sm">
      <strong class="text-white">KnowlEdge2 AI Tools for SBIR:</strong>
      <ul class="mt-2 space-y-1 text-slate-400">
        <li>→ <a href="https://sbirassistant.com" target="_blank" rel="noopener" class="text-orange-400 hover:underline">SBIR Assistant</a> — AI-powered BAA search and analysis</li>
        <li>→ <a href="https://setrassistant.com" target="_blank" rel="noopener" class="text-orange-400 hover:underline">SETR Assistant</a> — Systems Engineering Technical Review tool</li>
      </ul>
    </div>
  </div>
</ArticleLayout>
