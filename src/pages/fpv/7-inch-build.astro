---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'FPV Drones', href: '/fpv/' }];

const partsList = [
  {
    title: 'Matek Systems H743-Slim V3 Flight Controller',
    asin: 'B0C69X1G41',
    rating: '4.6/5',
    description: 'Our flight controller. STM32H743, 8 UARTs, 30×30mm. Runs ArduPilot Copter 4.6.2. Enough serial ports for GPS + companion + RC + telemetry simultaneously.',
    badge: 'We Fly This',
  },
  {
    title: 'NVIDIA Jetson Orin Nano Super Developer Kit (8GB)',
    asin: 'B0BZJTQ5YP',
    rating: '4.7/5',
    description: 'The brain. 67 TOPS AI inference, JetPack 6.2, CUDA 12.6, TensorRT 10.3. Runs YOLOv8 real-time, ROS2 Humble, Isaac ROS SLAM. The autonomy engine.',
    badge: 'Edge AI Core',
  },
  {
    title: 'SparkFun GPS-RTK2 Board (ZED-F9P)',
    asin: 'B07NBPNWNZ',
    rating: '4.6/5',
    description: 'RTK GPS with centimeter-level accuracy. UART to FC SERIAL3. ArduPilot GPS_TYPE=17. Essential for precision auto-landing on charging pad.',
    badge: 'Our GPS',
  },
  {
    title: 'DJI O3 Air Unit',
    asin: 'B0BBQT3TTS',
    rating: '4.5/5',
    description: '1080p/60fps digital FPV, ultra-low latency, on-board storage. Used for operator monitoring. Pairs with DJI Goggles 2.',
    badge: null,
  },
  {
    title: 'iFlight Xing2 2809 1250KV Motors (4-Pack)',
    asin: 'B09XTR2KFX',
    rating: '4.5/5',
    description: 'Our motors. Cinelifter-grade for heavy payload (Jetson). Buy 5 total — one spare is mandatory on a build this complex. 6S optimized.',
    badge: 'We Use These',
  },
  {
    title: 'Foxeer Reaper F4 65A 4-in-1 ESC (AM32)',
    asin: 'B0972ZKNT2',
    rating: '4.4/5',
    description: '65A continuous on 3-8S, 30×30mm. Configure via esc-configurator.com (not BLHeli Suite 32). No BEC — power GPS/receiver from FC 4V5 pad.',
    badge: 'We Use This',
  },
  {
    title: 'RadioMaster RP3 ELRS 2.4GHz Receiver',
    asin: 'B0BGL73623',
    rating: '4.7/5',
    description: 'The exact receiver on our build. Diversity nano, UFL antennas, T6/R6 pads. SERIAL7_PROTOCOL=23, RC_PROTOCOLS=512. Confirmed working.',
    badge: 'We Use This',
  },
  {
    title: 'Tattu R-Line V4.0 6S 1300mAh 130C (2-Pack)',
    asin: 'B099F921DM',
    rating: '4.6/5',
    description: 'High-C 6S packs for the 7" + Jetson payload. ~8-12 min patrol time per pack. Buy two minimum for meaningful patrol sessions.',
    badge: null,
  },
];

const aiStack = [
  { title: 'Jetson Orin Nano Super (8GB)', asin: 'B0BZJTQ5YP', highlight: '67 TOPS, JetPack 6.2', badge: 'Our Choice' },
  { title: 'Matek H743-Slim V3', asin: 'B0C69X1G41', highlight: 'H743, 8 UARTs, 30×30', badge: 'Our FC' },
  { title: 'SparkFun ZED-F9P GPS', asin: 'B07NBPNWNZ', highlight: 'RTK, 1cm accuracy', badge: 'Our GPS' },
  { title: 'DJI O3 Air Unit', asin: 'B0BBQT3TTS', highlight: '1080p, ultra-low latency', badge: null },
];

const softwareStack = [
  ['Flight Controller', 'ArduPilot Copter 4.6.2'],
  ['Companion OS', 'JetPack 6.2 (Ubuntu 22.04)'],
  ['Middleware', 'ROS2 Humble + MAVROS2'],
  ['AI Vision', 'YOLOv8n TRT FP16 (8.8MB engine)'],
  ['SLAM', 'Isaac ROS Visual SLAM 3.2.6'],
  ['Simulator', 'Isaac Sim 4.5 + Pegasus 5.1'],
];

const confirmed = [
  'Isaac Sim + Pegasus SITL: Full autonomous mission PASSED — arm → 5m → 5-waypoint box → land (2026-03-19)',
  'All 4 motors spinning at 30% throttle confirmed (2026-03-20)',
  'YOLOv8n TRT engine: 8.8MB FP16, real-time on Jetson Orin Nano Super',
  'Battery voltage: ~22.6V on 6S confirmed via MAVLink',
];
---
<ArticleLayout
  title="7-Inch Autonomous AI Guard Drone Build"
  description="KnowlEdge2 AI's flagship autonomous drone. Jetson Orin Nano, ArduPilot, RTK GPS, auto-landing, YOLOv8 on-board. Full hardware guide."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-8 text-slate-300">

    <!-- Build specs -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 not-prose">
      {[
        ['6S / 24V', 'Power'],
        ['8–12 min', 'Patrol time'],
        ['67 TOPS', 'On-board AI'],
        ['ArduPilot 4.6', 'Firmware'],
      ].map(([val, label]) => (
        <div class="rounded-xl border border-k2-primary/20 bg-k2-card p-4 text-center">
          <div class="text-base sm:text-xl font-extrabold text-k2-light leading-tight">{val}</div>
          <div class="text-xs text-slate-500 mt-1">{label}</div>
        </div>
      ))}
    </div>

    <!-- What this drone does -->
    <div class="rounded-xl border border-k2-primary/20 bg-k2-card overflow-hidden">
      <div class="h-1 bg-gradient-to-r from-k2-primary to-k2-blue"></div>
      <div class="p-6">
        <h2 class="text-xl font-bold text-white mb-3 flex items-center gap-2">
          <span>🛡️</span> What This Drone Does
        </h2>
        <div class="space-y-3 text-sm leading-relaxed text-slate-400">
          <p>This is the KnowlEdge2 AI guard drone — autonomous AI-powered property patrol. The <strong class="text-white">Jetson Orin Nano Super</strong> runs Isaac ROS Visual SLAM for navigation and YOLOv8n TensorRT (8.8MB FP16) for real-time object detection. MAVROS2 bridges ArduPilot to ROS2.</p>
          <p>The <strong class="text-white">ZED-F9P RTK GPS</strong> provides centimeter-level landing accuracy on the charging pad. The pilot holds RC only as a safety override — the drone arms, takes off, patrols, detects, and lands autonomously.</p>
        </div>
      </div>
    </div>

    <!-- Build Bundle -->
    <div class="rounded-xl border border-k2-primary/30 bg-gradient-to-br from-k2-primary/10 to-k2-card overflow-hidden not-prose">
      <div class="h-0.5 bg-gradient-to-r from-k2-primary to-k2-blue"></div>
      <div class="p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
        <div>
          <div class="text-xs font-bold text-k2-primary uppercase tracking-widest mb-1">One Click</div>
          <h3 class="text-lg font-extrabold text-white mb-1">Add complete build to Amazon cart</h3>
          <p class="text-sm text-slate-400">All 8 parts from this guide added at once. Review quantities before checkout — motors come in 4-packs; buy 2 packs for 5 total (4 + 1 spare).</p>
        </div>
        <a
          href="https://www.amazon.com/gp/aws/cart/add.html?ASIN.1=B0C69X1G41&Quantity.1=1&ASIN.2=B0BZJTQ5YP&Quantity.2=1&ASIN.3=B07NBPNWNZ&Quantity.3=1&ASIN.4=B0BBQT3TTS&Quantity.4=1&ASIN.5=B09XTR2KFX&Quantity.5=2&ASIN.6=B0972ZKNT2&Quantity.6=1&ASIN.7=B0BGL73623&Quantity.7=1&ASIN.8=B099F921DM&Quantity.8=2&tag=knowledge2ai-20"
          target="_blank"
          rel="noopener nofollow"
          class="flex-shrink-0 inline-flex items-center gap-2 bg-k2-primary hover:bg-k2-hover text-white font-bold px-6 py-3 rounded-xl text-sm whitespace-nowrap
                 transition-all duration-300 hover:shadow-[0_0_25px_rgba(6,182,212,0.4)] hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Add All to Cart →
        </a>
      </div>
    </div>

    <!-- Hardware -->
    <div>
      <h2 class="text-2xl font-bold text-white mb-6">Hardware Stack</h2>
      <div class="grid sm:grid-cols-2 gap-5 not-prose">
        {partsList.map(p => (
          <AffiliateCard {...p} />
        ))}
      </div>
    </div>

    <!-- Quick reference -->
    <div>
      <h2 class="text-2xl font-bold text-white mb-4">Core Components at a Glance</h2>
      <ProductTable caption="7-Inch Guard Drone Core Stack" products={aiStack} />
    </div>

    <!-- Software stack -->
    <div>
      <h2 class="text-2xl font-bold text-white mb-4">Software Stack (All Open Source)</h2>
      <div class="grid sm:grid-cols-2 gap-3 not-prose">
        {softwareStack.map(([label, value]) => (
          <div class="rounded-lg border border-k2-border bg-k2-card px-4 py-3 flex items-center justify-between gap-3">
            <span class="text-xs text-slate-500 flex-shrink-0">{label}</span>
            <span class="text-sm font-semibold text-white text-right">{value}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Confirmed results -->
    <div class="rounded-xl border border-k2-border bg-k2-card p-6">
      <h2 class="text-xl font-bold text-white mb-4">Confirmed Test Results</h2>
      <ul class="space-y-2.5">
        {confirmed.map(item => (
          <li class="flex items-start gap-3 text-sm">
            <svg class="w-4 h-4 text-k2-primary flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
            </svg>
            <span class="text-slate-400">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Warning -->
    <div class="rounded-xl border border-amber-500/25 bg-amber-900/10 p-5 text-sm flex items-start gap-3">
      <span class="text-amber-400 text-xl flex-shrink-0">⚠</span>
      <div class="text-slate-400 space-y-2">
        <p><strong class="text-amber-400">AI payload changes your power budget:</strong> The Jetson Orin Nano Super draws ~10W at idle and up to 25W under full YOLOv8 + SLAM inference. At 6S (22V), that's an extra 1.1A of continuous draw your battery sizing estimate must include. On a 1300mAh pack averaging 35A total, AI inference alone cuts flight time by roughly 8–12%. If patrol time matters, disable unused Isaac ROS nodes between detection events to reduce idle draw.</p>
        <p><strong class="text-amber-400">MAVLink 2 is required:</strong> The Jetson companion connects via SERIAL1. Set <code class="bg-k2-bg px-1 py-0.5 rounded text-xs text-k2-light">SERIAL1_BAUD=921</code> (921600) and <code class="bg-k2-bg px-1 py-0.5 rounded text-xs text-k2-light">SERIAL1_PROTOCOL=2</code> (MAVLink 2). MAVLink 1 drops critical message types needed by MAVROS2. Mismatch here is the most common reason ROS2 topics appear empty on first boot.</p>
      </div>
    </div>

  </div>
</ArticleLayout>
