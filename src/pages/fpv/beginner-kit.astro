---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'FPV Drones', href: '/fpv/' }];

const starterProducts = [
  {
    title: 'BetaFPV Cetus X Kit (RTF)',
    asin: 'B09NXMK4VD',
    price: '~$299',
    rating: '4.3/5',
    description: 'Best ready-to-fly starter kit. Includes goggles, controller, 3 batteries, and charger. Brushless motors, stable hover. Best way to learn before you solder.',
    badge: 'Best for Beginners',
  },
  {
    title: 'DJI Goggles 2 (HD Digital FPV)',
    asin: 'B0BJ8TWT4Y',
    price: '~$399',
    rating: '4.5/5',
    description: 'Step up to HD digital FPV. Micro OLED displays, 100ms latency, works with DJI O3 Air Unit used in our 7" guard drone build. This is the upgrade path.',
    badge: null,
  },
  {
    title: 'RadioMaster Boxer ELRS Controller',
    asin: 'B0C1WPMKXM',
    price: '~$109',
    rating: '4.6/5',
    description: 'Best value EdgeTX radio in 2026. ELRS 2.4GHz built-in, 2000mW range, compact gamepad form factor. Use this instead of the kit radio if you want to upgrade.',
    badge: 'Best Value Radio',
  },
  {
    title: 'HOTA D6 Pro LiPo Charger',
    asin: 'B09BGL6RLK',
    price: '~$152',
    rating: '4.7/5',
    description: '300W dual-port smart charger. Charges 1S–6S, displays IR values, fires AC power — no power supply needed. The last charger you\'ll ever buy.',
    badge: 'We Use This',
  },
  {
    title: 'GNB 6S 1300mAh 130C LiPo (2-Pack)',
    asin: 'B09TM14BCP',
    price: '~$58',
    rating: '4.4/5',
    description: '6S packs for 5" and 7" builds. High-C rating, consistent capacity. Buy two packs — you always need more batteries than you think.',
    badge: null,
  },
  {
    title: 'XT60 LiPo Safe Charging Bag (2-Pack)',
    asin: 'B07CLTD9TR',
    price: '~$14',
    rating: '4.6/5',
    description: 'Fire-retardant bags for LiPo charging and storage. Non-negotiable safety item. Cheap insurance against a house fire.',
    badge: 'Safety Essential',
  },
  {
    title: 'RJX Prop Stand / Blade Guard Kit',
    asin: 'B07MHHPLFY',
    price: '~$18',
    rating: '4.3/5',
    description: 'Prop guards for first flights indoors. Prevents the inevitable first crash from taking out walls, pets, or your face.',
    badge: null,
  },
  {
    title: 'Pinecil Smart Soldering Iron V2',
    asin: 'B096X7SB6R',
    price: '~$26',
    rating: '4.8/5',
    description: 'When you\'re ready to solder your first build — this is the iron to buy. USB-C powered, GaN-fast heat-up, open source. Better than $100 stations.',
    badge: 'Upgrade Path',
  },
];

const comparisonProducts = [
  { title: 'BetaFPV Cetus X Kit', asin: 'B09NXMK4VD', price: '~$299', highlight: 'RTF, beginner-safe', badge: 'Best RTF' },
  { title: 'Emax Tinyhawk III RTF', asin: 'B09Z34CWKV', price: '~$149', highlight: 'Micro, indoor-safe', badge: null },
  { title: 'GEPRC CineLog 25 HD', asin: 'B0C4VMXLTN', price: '~$219', highlight: '4K recording', badge: null },
  { title: 'iFlight Nazgul Evoque F5D', asin: 'B09NXMK4VD', price: '~$289', highlight: '5" freestyle/freestyle', badge: null },
];
---
<ArticleLayout
  title="FPV Beginner Kit 2026 — Everything You Need to Start"
  description="The complete shopping list for your first FPV drone, from someone who builds them for a living. 8 products, zero fluff."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-6 text-slate-300">
    <div class="bg-slate-900 border border-orange-500/20 rounded-xl p-5">
      <p class="text-sm leading-relaxed">
        <strong class="text-white">Who this is for:</strong> You want to fly FPV but haven't bought anything yet. This list gets you airborne safely, with a clear upgrade path to the autonomous AI drones we build at KnowlEdge2 AI. Total cost: <strong class="text-orange-400">~$350–$450</strong> for a complete setup.
      </p>
    </div>

    <h2 class="text-2xl font-bold text-white">The Short Answer</h2>
    <p>
      Buy the <strong class="text-white">BetaFPV Cetus X Kit</strong> to learn. Add the <strong class="text-white">HOTA D6 Pro charger</strong> immediately — the included charger is slow and unsafe for field use. Everything else below is the upgrade path once you're hooked.
    </p>

    <h2 class="text-2xl font-bold text-white pt-4">Starter Kit Products</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {starterProducts.map(p => (
        <AffiliateCard {...p} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">RTF Quad Comparison</h2>
    <p class="text-sm">All are ready-to-fly with controller and goggles included. BetaFPV wins on build quality; Tinyhawk wins on price for pure indoor practice.</p>

    <ProductTable
      caption="RTF FPV Kit Comparison (2026)"
      products={comparisonProducts}
    />

    <h2 class="text-2xl font-bold text-white pt-4">What NOT to Buy First</h2>
    <ul class="list-disc list-inside space-y-2 text-sm">
      <li><strong class="text-white">Don't buy DJI FPV Combo ($999)</strong> — too expensive to crash as a beginner, and not upgradeable toward autonomous builds.</li>
      <li><strong class="text-white">Don't buy a 5" freestyle quad first</strong> — too fast, too powerful, guaranteed immediate crash damage.</li>
      <li><strong class="text-white">Don't buy iSDT charger</strong> — requires a separate DC power supply. The HOTA is AC-direct.</li>
      <li><strong class="text-white">Don't skip LiPo bags</strong> — LiPos can and do catch fire. $14 is cheap insurance.</li>
    </ul>

    <h2 class="text-2xl font-bold text-white pt-4">The Upgrade Path</h2>
    <p class="text-sm">
      Once you can hover and fly basic lines: build a <a href="/fpv/4-inch-build/" class="text-orange-400 hover:underline">4" custom build</a>. Once you can fly that confidently: step up to the <a href="/fpv/7-inch-build/" class="text-orange-400 hover:underline">7" autonomous guard drone</a> — the KnowlEdge2 AI flagship build with Jetson Orin edge compute.
    </p>
  </div>
</ArticleLayout>
