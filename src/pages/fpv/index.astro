---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<Base
  title="Autonomous FPV Drone Builds"
  description="AI edge compute drone build guides — from beginner FPV kits to autonomous 7-inch guard drones with Jetson Orin and RTK GPS."
>
  <Nav />

  <!-- Hero -->
  <section class="relative min-h-[60vh] flex items-center overflow-hidden border-b border-k2-border">
    <div class="absolute inset-0 bg-k2-bg"></div>
    <div class="orb orb-a"></div>
    <div class="orb orb-b"></div>

    <div class="relative max-w-5xl mx-auto px-5 sm:px-8 py-20 w-full">
      <div class="fade-up" style="animation-delay:0ms">
        <a href="/" class="inline-flex items-center gap-1.5 text-xs text-slate-500 hover:text-k2-light transition-colors mb-6">
          ← KnowlEdge2 AI
        </a>
      </div>
      <div class="fade-up" style="animation-delay:60ms">
        <div class="text-xs font-bold text-k2-primary uppercase tracking-widest mb-4">FPV Drone Builds</div>
      </div>
      <h1 class="fade-up text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-5" style="animation-delay:100ms">
        We build drones<br/>
        <span class="gradient-text">that work for you.</span>
      </h1>
      <p class="fade-up text-lg text-slate-400 max-w-xl leading-relaxed" style="animation-delay:160ms">
        Not for racing. Not for YouTube. Autonomous property patrol, on-board AI vision,
        auto-landing and charging — running under the KnowlEdge2 AI product line.
        These guides cover the exact hardware stack.
      </p>
    </div>
  </section>

  <!-- Flagship — full width -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-16">
    <a href="/fpv/7-inch-build/" class="flagship-card group block relative rounded-2xl border border-k2-primary/25 bg-gradient-to-br from-k2-card via-k2-card to-k2-bg overflow-hidden
              hover:border-k2-primary/50 transition-all duration-500
              hover:shadow-[0_0_80px_rgba(6,182,212,0.12),0_24px_60px_rgba(0,0,0,0.5)]">
      <!-- Glow overlay on hover -->
      <div class="absolute inset-0 bg-gradient-to-br from-k2-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

      <div class="grid md:grid-cols-[auto_1fr] items-start gap-0">
        <!-- Label sidebar -->
        <div class="hidden md:flex flex-col items-center justify-between bg-k2-primary/10 border-r border-k2-primary/15 px-5 py-8 min-h-[200px]">
          <div class="writing-vertical text-xs font-bold text-k2-primary uppercase tracking-[0.2em]">Flagship</div>
          <svg class="w-5 h-5 text-k2-primary group-hover:translate-y-1 transition-transform mt-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </div>

        <!-- Content -->
        <div class="p-7 sm:p-10">
          <div class="flex flex-wrap items-center gap-3 mb-5">
            <span class="md:hidden text-xs font-bold text-k2-primary uppercase tracking-widest">Flagship</span>
            <span class="text-2xl">🤖</span>
            <span class="bg-k2-primary text-white text-xs font-bold px-2.5 py-1 rounded-lg">7″ Guard Drone</span>
          </div>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-3 group-hover:text-k2-light transition-colors">
            Autonomous AI Guard Drone
          </h2>
          <p class="text-slate-400 leading-relaxed mb-6 max-w-2xl">
            Jetson Orin Nano Super edge compute. ZED-F9P RTK GPS sub-cm accuracy.
            DJI O3 HD video. ArduPilot 4.6 autonomy. YOLOv8n TRT FP16 at 8.8ms on-board.
            This is the property guard dog — it patrols, detects, lands, and charges on its own.
          </p>
          <div class="flex flex-wrap gap-2 mb-6">
            {['Matek H743', 'Jetson Orin Nano', 'ZED-F9P RTK', 'DJI O3', 'Foxeer Reaper ESC', '6S LiPo'].map(tag => (
              <span class="text-xs bg-k2-bg border border-k2-border text-slate-400 px-3 py-1 rounded-full">{tag}</span>
            ))}
          </div>
          <div class="inline-flex items-center gap-2 text-k2-light font-bold text-sm group-hover:gap-3 transition-all">
            Full build guide — 45 min read
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </div>
        </div>
      </div>
    </a>
  </section>

  <!-- Other guides -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pb-20">
    <div class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-6">More guides</div>
    <div class="grid sm:grid-cols-3 gap-5">
      {[
        { href: '/fpv/beginner-kit/', icon: '🎮', label: 'Start Here', title: 'FPV Beginner Kit', desc: 'Everything you need to fly your first FPV drone in 2026. Complete kit with Amazon links.', time: '10 min' },
        { href: '/fpv/4-inch-build/', icon: '🔧', label: 'Build Guide', title: '4″ FPV Build', desc: 'JHEMCU F745 stack, AM32 ESC, 2406 motors. The indoor urban build for tight spaces.', time: '25 min' },
        { href: '/fpv/tools/', icon: '🛠️', label: 'Tools', title: "Builder's Tool Kit", desc: "Soldering stations, chargers, multimeters, smoke stoppers. What's actually on the bench.", time: '8 min' },
      ].map((g, i) => (
        <a href={g.href}
           class="guide-card group flex flex-col rounded-2xl border border-k2-border bg-k2-card p-6 overflow-hidden
                  hover:border-k2-primary/40 hover:-translate-y-1
                  transition-all duration-400
                  hover:shadow-[0_16px_48px_rgba(0,0,0,0.45)]"
           style={`animation-delay:${i * 60}ms`}>
          <div class="text-2xl mb-4">{g.icon}</div>
          <div class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">{g.label}</div>
          <h3 class="font-bold text-white text-lg mb-2 group-hover:text-k2-light transition-colors">{g.title}</h3>
          <p class="text-sm text-slate-400 leading-relaxed flex-1">{g.desc}</p>
          <div class="mt-5 flex items-center justify-between">
            <span class="text-xs text-slate-600">{g.time} read</span>
            <span class="text-k2-light text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
              Open
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</Base>

<style>
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(70px);
  animation: orbFloat 9s ease-in-out infinite;
  pointer-events: none;
}
.orb-a {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(6,182,212,0.10) 0%, transparent 70%);
  top: -80px; right: -60px;
  animation-delay: 0s;
}
.orb-b {
  width: 260px; height: 260px;
  background: radial-gradient(circle, rgba(59,130,246,0.07) 0%, transparent 70%);
  bottom: 20px; left: 20%;
  animation-delay: -4s;
}
@keyframes orbFloat {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(15px, -12px); }
}
.gradient-text {
  background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.fade-up {
  animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.guide-card {
  animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
}
.flagship-card {
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
.writing-vertical {
  writing-mode: vertical-rl;
  text-orientation: mixed;
  transform: rotate(180deg);
}
</style>
