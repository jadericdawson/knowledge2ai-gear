---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'FPV Drones', href: '/fpv/' }];

const tools = [
  {
    title: 'Pinecil Smart Soldering Iron V2',
    asin: 'B096X7SB6R',
    price: '~$26',
    rating: '4.8/5',
    description: 'RISC-V processor, USB-C PD power, reaches temp in 6 seconds. Better than irons costing 4× more. Best value purchase for any builder.',
    badge: 'Best Buy',
  },
  {
    title: 'Hakko FX-888D Digital Soldering Station',
    asin: 'B00ANZRT4M',
    price: '~$99',
    rating: '4.8/5',
    description: 'The professional bench standard. Analog feel with digital temp control. If you solder daily, get this. If you solder occasionally, get the Pinecil.',
    badge: 'Best Station',
  },
  {
    title: 'HOTA D6 Pro AC/DC LiPo Charger',
    asin: 'B09BGL6RLK',
    price: '~$152',
    rating: '4.7/5',
    description: '300W dual output, 1S–6S, AC power direct (no separate PSU). Displays cell IR. The only LiPo charger worth owning. We have two.',
    badge: 'We Use This',
  },
  {
    title: 'Klein Tools MM400 Digital Multimeter',
    asin: 'B0051G9F5K',
    price: '~$40',
    rating: '4.7/5',
    description: 'Auto-ranging, True RMS, CAT III 600V rated. Use it to trace shorts, verify voltage rails, and check motor continuity before first spinup.',
    badge: null,
  },
  {
    title: 'FPV Smoke Stopper / Current Limiter',
    asin: 'B07TZGWGMH',
    price: '~$15',
    rating: '4.4/5',
    description: 'In-line power limiter — current limits at ~10A if there\'s a short. Saved us from a fried ESC at least twice. Wire this between battery and build on first powerup.',
    badge: 'Safety Essential',
  },
  {
    title: 'MG Chemicals 835 No-Clean Flux Paste',
    asin: 'B00425FUW2',
    price: '~$12',
    rating: '4.7/5',
    description: 'Flux paste for motor wires to ESC pads. Makes soldering thick gauge wire dramatically easier. Tiny tube lasts a year.',
    badge: null,
  },
  {
    title: 'SEQURE Helping Hands / PCB Vise',
    asin: 'B01GZFVFFU',
    price: '~$18',
    rating: '4.3/5',
    description: 'Third-hand for holding boards and connectors while soldering. The bendy-arm type works fine. Essential for ESC pad soldering.',
    badge: null,
  },
  {
    title: 'Kaisi Heat Shrink Tubing Kit',
    asin: 'B08K3X2JZC',
    price: '~$10',
    rating: '4.5/5',
    description: '3:1 dual-wall shrink tubing in multiple diameters. Use on battery leads, motor wires, and XT60 connectors. Buy once, use for years.',
    badge: null,
  },
  {
    title: 'SkyRC B6 Mini V2 LiPo Battery Checker',
    asin: 'B00BAXFWGE',
    price: '~$14',
    rating: '4.5/5',
    description: 'Per-cell voltage display and buzzer alarm. Wire this on your bench LiPo to catch any cell imbalance before it becomes a fire.',
    badge: null,
  },
  {
    title: 'LiPo Safe Fire-Retardant Charging Bags (3-pack)',
    asin: 'B07CLTD9TR',
    price: '~$16',
    rating: '4.6/5',
    description: 'Always charge LiPos in these. Always store LiPos in these. A thermal event in a 6S pack will burn your house down. This is not optional.',
    badge: 'Safety Essential',
  },
];

const chargerComparison = [
  { title: 'HOTA D6 Pro', asin: 'B09BGL6RLK', price: '~$152', highlight: '300W, dual, AC direct', badge: 'Our Pick' },
  { title: 'ISDT Q8 Plus', asin: 'B09NXMK4VD', price: '~$55', highlight: '500W, needs PSU', badge: null },
  { title: 'Toolkit RC M6D', asin: 'B08B3LDR3X', price: '~$69', highlight: '30W×2, AC direct, budget', badge: 'Budget Pick' },
  { title: 'Junsi iCharger 4010 Duo', asin: 'B07TZGWGMH', price: '~$319', highlight: 'Pro-grade, 1000W', badge: null },
];
---
<ArticleLayout
  title="FPV Builder's Tool Kit — What's Actually on My Bench"
  description="Every tool we use building autonomous drones at KnowlEdge2 AI. Soldering stations, LiPo chargers, multimeters, safety gear. What matters vs. what YouTube sells you."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-6 text-slate-300">
    <div class="bg-slate-900 border border-orange-500/20 rounded-xl p-5">
      <p class="text-sm leading-relaxed">
        <strong class="text-white">The short version:</strong> You need a soldering iron, a LiPo charger, a multimeter, and a smoke stopper. Everything else is nice-to-have. This list covers the exact tools on our build bench — including what we've broken and replaced.
      </p>
    </div>

    <h2 class="text-2xl font-bold text-white">Bench Tools</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {tools.map(t => (
        <AffiliateCard {...t} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">LiPo Charger Comparison</h2>
    <p class="text-sm">The HOTA D6 Pro is the buy-once option. The Toolkit RC is fine if you're budget-constrained and only need to charge 1-2 packs at a time.</p>
    <ProductTable caption="LiPo Charger Comparison (2026)" products={chargerComparison} />

    <h2 class="text-2xl font-bold text-white pt-4">What You Don't Need</h2>
    <ul class="list-disc list-inside space-y-2 text-sm">
      <li><strong class="text-white">Hot air rework station</strong> — useful but not required for first 10 builds. Drag soldering works for surface-mount work.</li>
      <li><strong class="text-white">Oscilloscope</strong> — not needed for drone builds. MAVLink telemetry gives you all the diagnostics you need.</li>
      <li><strong class="text-white">$200+ soldering station</strong> — the Pinecil does 95% of what the Hakko does at 25% the cost.</li>
      <li><strong class="text-white">Lab power supply</strong> — only needed for high-current ESC testing. Use the smoke stopper instead.</li>
    </ul>

    <h2 class="text-2xl font-bold text-white pt-4">Build With These</h2>
    <p class="text-sm">
      Ready to solder? Start with the <a href="/fpv/4-inch-build/" class="text-orange-400 hover:underline">4-inch build guide</a>, or go straight to the <a href="/fpv/7-inch-build/" class="text-orange-400 hover:underline">7-inch autonomous guard drone</a>.
    </p>
  </div>
</ArticleLayout>
