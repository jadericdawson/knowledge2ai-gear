---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'Farm Tech', href: '/farm-tech/' }];

const farmProducts = [
  {
    title: 'Ambient Weather WS-2902 WiFi Weather Station',
    asin: 'B01N5TEHLI',
    price: '~$189',
    rating: '4.4/5',
    description: 'Full professional weather station with WiFi upload to AmbientWeather.net and Weather Underground. Wind, rain, UV, solar, outdoor temp/humidity. What we run at Dawson Family Farm.',
    badge: 'We Run This',
  },
  {
    title: 'Orbit B-hyve 12-Zone WiFi Smart Irrigation Controller',
    asin: 'B01D15HOTU',
    price: '~$89',
    rating: '4.2/5',
    description: 'WiFi irrigation controller with weather skip. Integrates with Alexa, pulls local weather to skip cycles after rain. 12 zones for larger operations.',
    badge: null,
  },
  {
    title: 'Raspberry Pi 5 (8GB)',
    asin: 'B0CK2FCG1K',
    price: '~$80',
    rating: '4.5/5',
    description: 'Brain for farm automation. Runs Node-RED for sensor aggregation, MQTT broker, Home Assistant integration. Low power, fanless operation.',
    badge: 'DIY Hub',
  },
  {
    title: 'HHCC Plant Monitor 3-Pack (Bluetooth Soil Sensor)',
    asin: 'B0B6QVF3M4',
    price: '~$35',
    rating: '4.3/5',
    description: 'Bluetooth sensors measuring soil moisture, temperature, light, and fertility. 3-pack covers multiple beds or field locations. Battery-powered, app-connected.',
    badge: null,
  },
  {
    title: 'Seagate IronWolf Pro 4TB NAS Drive',
    asin: 'B07SY4T6F5',
    price: '~$89',
    rating: '4.5/5',
    description: 'NAS storage for farm data logging — weather history, sensor records, drone telemetry. 7200 RPM, designed for always-on NAS environments.',
    badge: null,
  },
  {
    title: 'APC BX1500M 1500VA UPS',
    asin: 'B06VY6FXMM',
    price: '~$229',
    rating: '4.7/5',
    description: 'Battery backup for farm automation hub and NAS. Rural power is unreliable — a UPS prevents data loss on the farm server during outages.',
    badge: 'Rural Essential',
  },
  {
    title: 'Noctua NF-A4x10 5V Fan (Pi / NAS Cooling)',
    asin: 'B07DXRNYNX',
    price: '~$16',
    rating: '4.7/5',
    description: 'Silent 40mm fan for Raspberry Pi 5 active cooling. Pi 5 throttles under sustained sensor polling loads without airflow — this fixes it quietly.',
    badge: null,
  },
  {
    title: 'Samsung 970 EVO Plus 1TB NVMe (Pi 5 Boot)',
    asin: 'B07MFZY2F2',
    price: '~$79',
    rating: '4.8/5',
    description: 'NVMe boot drive for Raspberry Pi 5 via M.2 HAT. Much faster than SD cards, survives the write cycles of continuous sensor logging.',
    badge: 'Upgrade Essential',
  },
];

const weatherComparison = [
  { title: 'Ambient Weather WS-2902', asin: 'B01N5TEHLI', price: '~$189', highlight: 'Full station, WiFi API', badge: 'Our Pick' },
  { title: 'Orbit B-hyve 12-Zone', asin: 'B01D15HOTU', price: '~$89', highlight: 'Smart irrigation, 12 zones', badge: null },
  { title: 'Raspberry Pi 5 (8GB)', asin: 'B0CK2FCG1K', price: '~$80', highlight: 'Automation hub, Node-RED', badge: 'DIY Hub' },
  { title: 'APC BX1500M UPS', asin: 'B06VY6FXMM', price: '~$229', highlight: '1500VA, 10 outlets', badge: null },
];
---
<ArticleLayout
  title="Farm Tech — Precision Agriculture Gear"
  description="Weather stations, soil sensors, irrigation controllers, and automation hardware for modern farm operations. From Dawson Family Farm & Services LLC."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-6 text-slate-300">
    <div class="bg-slate-900 border border-orange-500/20 rounded-xl p-5">
      <p class="text-sm leading-relaxed">
        <strong class="text-white">From Dawson Family Farm & Services LLC:</strong> We operate a real farm in Ohio and use real data. This page covers the monitoring and automation hardware we've deployed — weather stations, soil sensors, irrigation controllers, and the Raspberry Pi hub that ties it all together.
      </p>
    </div>

    <h2 class="text-2xl font-bold text-white">Farm Hardware</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {farmProducts.map(p => (
        <AffiliateCard {...p} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">Farm Tech Quick Reference</h2>
    <ProductTable caption="Farm Automation Core Stack" products={weatherComparison} />

    <h2 class="text-2xl font-bold text-white pt-4">The Drone Connection</h2>
    <p class="text-sm leading-relaxed">
      Our <a href="/fpv/7-inch-build/" class="text-orange-400 hover:underline">autonomous guard drone</a> can overlay weather station data with patrol telemetry — wind speed affects flight envelope, temperature affects battery performance. The same Jetson running security detection can run crop stress analysis. This is the second product vertical for KnowlEdge2 AI drones.
    </p>
  </div>
</ArticleLayout>
