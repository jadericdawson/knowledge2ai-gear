---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import ProductTable from '../../components/ProductTable.astro';

const breadcrumb = [{ label: 'AI Gear', href: '/ai-gear/' }];

const jetsonGear = [
  {
    title: 'NVIDIA Jetson Orin Nano Super Developer Kit (8GB)',
    asin: 'B0BZJTQ5YP',
    price: '~$499',
    rating: '4.7/5',
    description: 'Our primary edge compute platform. 67 TOPS, JetPack 6.2, CUDA 12.6, TensorRT 10.3. Runs YOLOv8 real-time, Isaac ROS SLAM, full ROS2 stack on the guard drone.',
    badge: 'We Run This',
  },
  {
    title: 'Samsung 970 EVO Plus 1TB NVMe SSD',
    asin: 'B07MFZY2F2',
    price: '~$79',
    rating: '4.8/5',
    description: 'Boot drive for Jetson via M.2 slot. Dramatically faster than microSD for Isaac ROS container pulls and model storage. Mandatory upgrade.',
    badge: 'Upgrade Essential',
  },
  {
    title: 'Noctua NF-A4x10 5V PWM Fan (40mm)',
    asin: 'B07DXRNYNX',
    price: '~$16',
    rating: '4.7/5',
    description: 'Silent 40mm 5V fan for Jetson heatsink upgrade. The stock fan is undersized for sustained GPU inference load. Active cooling prevents thermal throttling mid-flight.',
    badge: null,
  },
  {
    title: 'Anker Nano 65W GaN USB-C Charger',
    asin: 'B08T5QN2TR',
    price: '~$22',
    rating: '4.7/5',
    description: 'Compact GaN charger for Jetson USB-C power. Clean regulated power better than barrel-jack adapters. Supports 65W negotiation.',
    badge: null,
  },
];

const devGear = [
  {
    title: 'Logitech MX Master 3S Mouse',
    asin: 'B0BS9VVQPD',
    price: '~$99',
    rating: '4.8/5',
    description: 'Multi-device Bluetooth, ultra-fast scroll wheel, quiet clicks. Switch between Jetson, desktop, and laptop with one button. Daily driver on our build bench.',
    badge: 'Daily Driver',
  },
  {
    title: 'Samsung 970 EVO Plus 1TB NVMe (Desktop)',
    asin: 'B07MFZY2F2',
    price: '~$79',
    rating: '4.8/5',
    description: 'Same drive we use in Jetson, also great for desktop AI workstation secondary storage. Dataset and model cache drive.',
    badge: null,
  },
  {
    title: 'EMEET S600 4K Webcam',
    asin: 'B0CYQ5P6T7',
    price: '~$120',
    rating: '4.5/5',
    description: 'Sony 1/2.55" sensor, PDAF autofocus, 1080p/60fps, dual noise-canceling mics, privacy cover. What we use for video calls and remote demos. Works plug-and-play on Linux/Jetson.',
    badge: 'We Own This',
  },
  {
    title: 'YubiKey 5 NFC Security Key',
    asin: 'B07HBD71HL',
    price: '~$50',
    rating: '4.7/5',
    description: 'Hardware MFA for Azure portal, GitHub, and any federated identity. Tap NFC on phone or USB on desktop. Mandatory for CMMC-aligned environments.',
    badge: null,
  },
  {
    title: 'APC BX1500M 1500VA UPS Battery Backup',
    asin: 'B06VY6FXMM',
    price: '~$229',
    rating: '4.7/5',
    description: 'Power backup for AI workstation. Running Isaac Sim on RTX 3070 with GPU load can trip surge protectors — a UPS prevents mid-simulation shutdowns.',
    badge: 'Prevents Headaches',
  },
];

const aiComparison = [
  { title: 'Jetson Orin Nano Super (8GB)', asin: 'B0BZJTQ5YP', price: '~$499', highlight: '67 TOPS, edge compute', badge: 'Our Pick' },
  { title: 'Samsung 970 EVO Plus 1TB', asin: 'B07MFZY2F2', price: '~$79', highlight: 'NVMe, Jetson M.2', badge: null },
  { title: 'Noctua NF-A4x10 5V Fan', asin: 'B07DXRNYNX', price: '~$16', highlight: '40mm, silent, 5V', badge: null },
  { title: 'YubiKey 5 NFC', asin: 'B07HBD71HL', price: '~$50', highlight: 'Hardware MFA, USB+NFC', badge: null },
];
---
<ArticleLayout
  title="AI Developer Gear — Edge Compute & Dev Hardware"
  description="The hardware stack powering KnowlEdge2 AI products. Jetson Orin, NVMe upgrades, development monitors, and the tools behind real AI deployments."
  breadcrumb={breadcrumb}
  lastUpdated="March 2026"
>
  <div class="space-y-6 text-slate-300">
    <div class="bg-slate-900 border border-orange-500/20 rounded-xl p-5">
      <p class="text-sm leading-relaxed">
        <strong class="text-white">Context:</strong> KnowlEdge2 AI builds autonomous drone systems and AI applications deployed to Azure and edge hardware. This page covers the physical gear behind those deployments — Jetson Orin for drone edge compute and desktop AI workstation accessories.
      </p>
    </div>

    <h2 class="text-2xl font-bold text-white">Jetson Edge Compute</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {jetsonGear.map(p => (
        <AffiliateCard {...p} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">Dev Workstation Accessories</h2>
    <div class="grid sm:grid-cols-2 gap-5 not-prose">
      {devGear.map(p => (
        <AffiliateCard {...p} />
      ))}
    </div>

    <h2 class="text-2xl font-bold text-white pt-4">Quick Comparison</h2>
    <ProductTable caption="AI Gear Quick Reference" products={aiComparison} />

    <h2 class="text-2xl font-bold text-white pt-4">Our Deployed Stack</h2>
    <div class="grid sm:grid-cols-2 gap-4 text-sm not-prose">
      {[
        { label: 'Edge inference', value: 'Jetson Orin Nano Super — YOLOv8n TRT FP16' },
        { label: 'Simulation', value: 'Isaac Sim 4.5 + Pegasus 5.1 on RTX 3070' },
        { label: 'Cloud', value: 'Azure East US 2 — Static Web Apps, App Service' },
        { label: 'AI apps', value: 'KnowlEdge2 AI, SBIR Assistant, SETR Assistant' },
      ].map(item => (
        <div class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-3">
          <div class="text-xs text-slate-500 mb-1">{item.label}</div>
          <div class="font-medium text-white">{item.value}</div>
        </div>
      ))}
    </div>

    <div class="bg-amber-900/20 border border-amber-500/30 rounded-xl p-4 text-sm">
      <strong class="text-amber-400">⚠ GPU + surge protectors:</strong> Heavy GPU load (Isaac Sim, training) on a desktop RTX 3070 can trip basic surge strips. Use a UPS like the APC BX1500M — not a $15 power bar.
    </div>
  </div>
</ArticleLayout>
