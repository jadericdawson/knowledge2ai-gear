---
export interface Props {
  title: string;
  asin: string;
  rating?: string;
  image?: string;
  description: string;
  badge?: string;
  tag?: string;
}

const {
  title,
  asin,
  rating,
  image,
  description,
  badge,
  tag = 'knowledge2ai-20',
} = Astro.props;

const affiliateUrl = `https://www.amazon.com/dp/${asin}?tag=${tag}`;
const amazonImage = `https://ws-na.amazon-adsystem.com/widgets/q?_encoding=UTF8&MarketPlace=US&ASIN=${asin}&ServiceVersion=20070822&ID=AsinImage&WS=1&Format=_SL250_&tag=${tag}`;
const imgSrc = image || amazonImage;
---
<div class="product-card group relative flex flex-col rounded-2xl border border-k2-border bg-k2-card overflow-hidden
            hover:border-k2-primary/50 hover:-translate-y-1.5
            transition-all duration-400
            hover:shadow-[0_24px_64px_rgba(0,0,0,0.5),0_0_0_1px_rgba(6,182,212,0.15)]">

  {badge && (
    <div class="absolute top-3 left-3 z-10 bg-k2-primary text-white text-xs font-bold px-2.5 py-1 rounded-lg shadow-lg">
      {badge}
    </div>
  )}

  <!-- Product image — full width -->
  <a href={affiliateUrl} target="_blank" rel="noopener nofollow" class="block overflow-hidden bg-white">
    <div class="h-48 sm:h-52 flex items-center justify-center p-4 bg-white overflow-hidden">
      <img
        src={imgSrc}
        alt={title}
        class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-bold text-white text-base leading-snug group-hover:text-k2-light transition-colors flex-1">
        {title}
      </h3>
      {rating && (
        <div class="flex items-center gap-1 flex-shrink-0 mt-0.5">
          <svg class="w-3.5 h-3.5 text-k2-light fill-current" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span class="text-xs text-slate-400 font-medium">{rating}</span>
        </div>
      )}
    </div>

    <p class="text-sm text-slate-400 leading-relaxed flex-1 mb-5">{description}</p>

    <a
      href={affiliateUrl}
      target="_blank"
      rel="noopener nofollow"
      class="flex items-center justify-center gap-2 w-full bg-k2-primary hover:bg-k2-hover text-white font-bold text-sm py-3 px-4 rounded-xl
             transition-all duration-300 hover:shadow-[0_0_20px_rgba(6,182,212,0.4)]"
    >
      Check Price on Amazon
      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
    </a>
  </div>
</div>

<style>
.transition-all { transition-duration: 400ms; }
</style>
