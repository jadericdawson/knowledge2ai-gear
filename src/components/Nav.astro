---
const builds = [
  { label: 'Beginner Kit',    href: '/fpv/beginner-kit/',  desc: 'Start here — complete kit' },
  { label: '4″ FPV Build',    href: '/fpv/4-inch-build/',  desc: 'Indoor urban freestyle quad' },
  { label: '7″ Guard Drone',  href: '/fpv/7-inch-build/',  desc: 'AI autonomous patrol drone', badge: 'Flagship' },
  { label: "Builder's Tools", href: '/fpv/tools/',          desc: 'Soldering, chargers, bench' },
];
const guides = [
  { label: 'Motor Selection', href: '/fpv/motor-guide/',   desc: 'KV, stator size, thrust math' },
  { label: 'Battery Guide',   href: '/fpv/battery-guide/', desc: 'Cell count, C rating, LiPo' },
  { label: 'Flight Stack',    href: '/fpv/fc-guide/',       desc: 'FC + ESC sizing & protocols' },
  { label: 'Charger Guide',   href: '/fpv/charger-guide/',  desc: 'Charge rates, parallel, safety' },
];

const currentPath = Astro.url.pathname;
const isFpv = currentPath.startsWith('/fpv/');
---
<header class="border-b border-k2-border bg-k2-bg/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-20 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity flex-shrink-0">
      <img src="/k2-logo.png" alt="KnowlEdge2 AI" class="h-16 w-auto object-contain" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">

      <!-- FPV Drones — mega dropdown -->
      <li class="relative group">
        <a
          href="/fpv/"
          class={`px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center gap-1.5 ${
            isFpv ? 'text-k2-light bg-k2-card' : 'text-slate-300 hover:text-white hover:bg-k2-card'
          }`}
        >
          FPV Drones
          <svg class="w-3 h-3 opacity-50 group-hover:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/>
          </svg>
        </a>

        <!-- Dropdown panel -->
        <div class="nav-dropdown absolute top-full left-1/2 -translate-x-1/2 pt-3 z-50
                    opacity-0 translate-y-2 pointer-events-none
                    group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto
                    transition-all duration-200 ease-out">
          <div class="w-[500px] rounded-2xl border border-k2-border bg-k2-card/98 backdrop-blur-xl
                      shadow-[0_24px_80px_rgba(0,0,0,0.7),0_0_0_1px_rgba(6,182,212,0.08)]">
            <div class="h-0.5 bg-gradient-to-r from-k2-primary to-k2-blue rounded-t-2xl"></div>
            <div class="grid grid-cols-2 p-3 gap-1">

              <!-- Builds column -->
              <div>
                <div class="text-[9px] font-bold text-slate-600 uppercase tracking-[0.15em] px-2.5 py-2">Build Guides</div>
                {builds.map(b => (
                  <a href={b.href} class="group/item flex items-start gap-0 px-2.5 py-2.5 rounded-xl hover:bg-k2-panel transition-colors">
                    <div class="flex-1">
                      <div class="flex items-center gap-1.5">
                        <span class="text-sm font-semibold text-white group-hover/item:text-k2-light transition-colors leading-tight">{b.label}</span>
                        {b.badge && <span class="text-[8px] font-bold bg-k2-primary/90 text-white px-1.5 py-0.5 rounded-md leading-none">{b.badge}</span>}
                      </div>
                      <div class="text-xs text-slate-500 mt-0.5">{b.desc}</div>
                    </div>
                  </a>
                ))}
              </div>

              <!-- Guides column -->
              <div class="border-l border-k2-border pl-1">
                <div class="text-[9px] font-bold text-slate-600 uppercase tracking-[0.15em] px-2.5 py-2">Component Guides</div>
                {guides.map(g => (
                  <a href={g.href} class="group/item flex items-start px-2.5 py-2.5 rounded-xl hover:bg-k2-panel transition-colors">
                    <div class="flex-1">
                      <div class="text-sm font-semibold text-white group-hover/item:text-k2-light transition-colors leading-tight">{g.label}</div>
                      <div class="text-xs text-slate-500 mt-0.5">{g.desc}</div>
                    </div>
                  </a>
                ))}
              </div>

            </div>
            <!-- Footer hint -->
            <div class="px-4 pb-3 border-t border-k2-border/50 mt-1 pt-2.5 flex items-center justify-between">
              <span class="text-[10px] text-slate-600">All guides tie into real builds we fly</span>
              <a href="/fpv/" class="text-[10px] font-semibold text-k2-light hover:text-white transition-colors">All FPV →</a>
            </div>
          </div>
        </div>
      </li>

      <!-- AI Gear -->
      <li>
        <a href="/ai-gear/" class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
          currentPath.startsWith('/ai-gear/') ? 'text-k2-light bg-k2-card' : 'text-slate-300 hover:text-white hover:bg-k2-card'
        }`}>AI Gear</a>
      </li>

      <!-- About -->
      <li>
        <a href="/about/" class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
          currentPath.startsWith('/about/') ? 'text-k2-light bg-k2-card' : 'text-slate-300 hover:text-white hover:bg-k2-card'
        }`}>About</a>
      </li>
    </ul>

    <!-- K2AI app link -->
    <a
      href="https://knowledge2-ai.com"
      target="_blank"
      rel="noopener"
      class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-k2-light border border-k2-border hover:border-k2-primary/60 hover:bg-k2-card px-3 py-1.5 rounded-lg transition-colors"
    >
      <img src="/k2-symbol.png" alt="" width="14" height="14" class="w-3.5 h-3.5 object-contain" />
      knowledge2-ai.com ↗
    </a>

    <!-- Mobile toggle -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-slate-300 hover:text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-k2-border bg-k2-bg">
    <div class="max-w-6xl mx-auto px-4 py-3 space-y-0.5">
      <div class="text-[9px] font-bold text-slate-600 uppercase tracking-widest px-3 pt-2 pb-1">Build Guides</div>
      {builds.map(b => (
        <a href={b.href} class="flex items-center justify-between px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-k2-card transition-colors">
          <span>{b.label}</span>
          {b.badge && <span class="text-[8px] font-bold bg-k2-primary text-white px-1.5 py-0.5 rounded">{b.badge}</span>}
        </a>
      ))}
      <div class="text-[9px] font-bold text-slate-600 uppercase tracking-widest px-3 pt-3 pb-1">Component Guides</div>
      {guides.map(g => (
        <a href={g.href} class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-k2-card transition-colors">{g.label}</a>
      ))}
      <div class="border-t border-k2-border pt-2 mt-2">
        <a href="/ai-gear/" class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-k2-card transition-colors">AI Gear</a>
        <a href="/about/" class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-300 hover:text-white hover:bg-k2-card transition-colors">About</a>
      </div>
    </div>
  </div>
</header>

<style>
.nav-dropdown {
  /* Prevent gap between nav item and dropdown from dismissing on hover */
  filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
}
</style>
