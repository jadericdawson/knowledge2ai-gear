---
const navLinks = [
  { label: 'FPV Drones', href: '/fpv/' },
  { label: 'AI Gear', href: '/ai-gear/' },
  { label: 'Farm Tech', href: '/farm-tech/' },
  { label: 'SBIR Tools', href: '/sbir-tools/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---
<header class="border-b border-slate-800 bg-slate-950/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 text-white font-bold text-lg hover:text-orange-400 transition-colors">
      <img src="/favicon.svg" alt="" width="24" height="24" />
      KnowlEdge2 AI
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href) && link.href !== '/'
                ? 'text-orange-400 bg-slate-800'
                : 'text-slate-300 hover:text-white hover:bg-slate-800'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button (CSS-only) -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-slate-300 hover:text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile menu (CSS-only toggle) -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-slate-800 bg-slate-950">
    <ul class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
