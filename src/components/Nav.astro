---
const navLinks = [
  { label: 'FPV Drones', href: '/fpv/' },
  { label: 'AI Gear', href: '/ai-gear/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---
<header class="border-b border-k2-border bg-k2-bg/95 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 hover:opacity-85 transition-opacity">
      <img src="/k2-symbol.png" alt="KnowlEdge2 AI" width="32" height="32" class="w-8 h-8 object-contain" />
      <span class="font-bold text-white text-base leading-tight hidden sm:block">KnowlEdge2 AI<span class="block text-xs font-normal text-k2-light">Gear Guides</span></span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              currentPath.startsWith(link.href) && link.href !== '/'
                ? 'text-k2-light bg-k2-card'
                : 'text-slate-300 hover:text-white hover:bg-k2-card'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- K2AI app link -->
    <a
      href="https://knowledge2-ai.com"
      target="_blank"
      rel="noopener"
      class="hidden md:inline-flex items-center gap-1.5 text-xs font-semibold text-k2-light border border-k2-border hover:border-k2-primary/60 hover:bg-k2-card px-3 py-1.5 rounded-lg transition-colors"
    >
      <img src="/k2-symbol.png" alt="" width="14" height="14" class="w-3.5 h-3.5 object-contain" />
      knowledge2-ai.com ↗
    </a>

    <!-- Mobile menu toggle -->
    <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 text-slate-300 hover:text-white">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
  <div class="hidden peer-checked:block md:hidden border-t border-k2-border bg-k2-bg">
    <ul class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block px-3 py-2 rounded-md text-sm font-medium text-slate-300 hover:text-white hover:bg-k2-card transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
