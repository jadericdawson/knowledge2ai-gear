---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  breadcrumb?: Array<{ label: string; href: string }>;
  lastUpdated?: string;
}

const { title, description, breadcrumb = [], lastUpdated } = Astro.props;
---
<Base title={title} description={description}>
  <Nav />

  <!-- Hero header -->
  <div class="relative overflow-hidden border-b border-k2-border">
    <div class="absolute inset-0 bg-gradient-to-br from-k2-primary/8 via-k2-bg to-k2-bg pointer-events-none"></div>
    <div class="max-w-5xl mx-auto px-5 sm:px-8 py-14 sm:py-20 relative">
      {breadcrumb.length > 0 && (
        <nav class="text-xs text-slate-500 mb-5 flex items-center gap-1.5 flex-wrap" aria-label="Breadcrumb">
          <a href="/" class="hover:text-k2-light transition-colors">Home</a>
          {breadcrumb.map((crumb) => (
            <>
              <span class="text-slate-700">/</span>
              <a href={crumb.href} class="hover:text-k2-light transition-colors">{crumb.label}</a>
            </>
          ))}
          <span class="text-slate-700">/</span>
          <span class="text-slate-400">{title}</span>
        </nav>
      )}
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-4">{title}</h1>
      {description && <p class="text-lg text-slate-400 max-w-2xl leading-relaxed">{description}</p>}
      {lastUpdated && <p class="text-xs text-slate-600 mt-4">Updated {lastUpdated}</p>}
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-5 sm:px-8 py-12">
    <slot />

    <!-- Affiliate disclosure -->
    <div class="mt-14 p-5 bg-k2-card border border-k2-border rounded-xl text-sm text-slate-400">
      <strong class="text-slate-300">Affiliate disclosure:</strong> As an Amazon Associate, KnowlEdge2 AI earns from qualifying purchases. Links on this page may be affiliate links.
      <a href="/about#disclosure" class="text-k2-light hover:underline ml-1">Full disclosure →</a>
    </div>
  </main>

  <Footer />
</Base>
